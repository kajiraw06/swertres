# =============================================
#  SWERTRES BACKEND — ENVIRONMENT VARIABLES
# =============================================

# Server
PORT=5000
NODE_ENV=development

# Supabase (get these from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret (change to a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# PayMongo API (for GCash payments) — get keys at https://dashboard.paymongo.com
PAYMONGO_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
PAYMONGO_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
PAYMONGO_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Your app's public URL (used for payment redirects)
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Admin credentials (for first-time setup)
ADMIN_PHONE=09XXXXXXXXX
ADMIN_PASSWORD=admin_password_here
ADMIN_NAME=Admin
